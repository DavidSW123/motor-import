# ── Sesión ───────────────────────────────────────────────────────
SESSION_SECRET=cambia-esto-por-una-cadena-secreta-larga

# ── Base de datos (producción: Turso) ────────────────────────────
# Deja vacío para usar SQLite local en desarrollo
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu-token-de-turso

# ── Almacenamiento de imágenes (producción: Cloudinary) ──────────
# Deja vacío para guardar imágenes en disco local (dev)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ── Entorno ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
