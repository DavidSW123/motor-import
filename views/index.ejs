<%- include('partials/header', { title: 'Coches y autocaravanas seleccionados' }) %>

<!-- ── HERO ─────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>

  <div class="hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Coches y campers seleccionados
    </div>
    <h1 class="hero-title">
      Tu próximo viaje empieza<br>
      <span class="text-gold">con el vehículo adecuado</span>
    </h1>
    <p class="hero-subtitle">
      Coches de calidad y autocaravanas listas para la aventura.<br>
      Selección cuidada · Documentación completa · Trato cercano.
    </p>
    <div class="hero-actions">
      <a href="/coches" class="btn btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Ver coches
      </a>
      <a href="/campers" class="btn btn-outline btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="9" width="14" height="9" rx="1.5"/><path d="M16 12 H22 V18 H16"/><circle cx="6" cy="20" r="2"/><circle cx="18" cy="20" r="2"/></svg>
        Ver campers
      </a>
    </div>
  </div>

  <!-- Buscador rápido -->
  <div class="hero-search">
    <form action="/coches" method="get" class="search-form">
      <div class="search-group">
        <label for="hs-categoria">Tipo</label>
        <select id="hs-categoria" name="categoria" class="form-select">
          <option value="">Todos</option>
          <option value="coche">Coches</option>
          <option value="camper">Campers</option>
        </select>
      </div>
      <div class="search-group">
        <label for="hs-marca">Marca</label>
        <input type="text" id="hs-marca" name="marca" placeholder="BMW, Mercedes, Volkswagen…" class="form-input" autocomplete="off">
      </div>
      <div class="search-group">
        <label for="hs-precio">Precio máximo</label>
        <select id="hs-precio" name="precio_max" class="form-select">
          <option value="">Sin límite</option>
          <option value="10000">10.000 €</option>
          <option value="15000">15.000 €</option>
          <option value="25000">25.000 €</option>
          <option value="40000">40.000 €</option>
          <option value="60000">60.000 €</option>
          <option value="90000">90.000 €</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Buscar
      </button>
    </form>
  </div>
</section>

<!-- ── STATS ─────────────────────────────────────────────────── -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-number" data-count="<%= stats.coches %>"><%= stats.coches %></div>
        <div class="stat-label">Coches en stock</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" data-count="<%= stats.campers %>"><%= stats.campers %></div>
        <div class="stat-label">Campers en stock</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">100%</div>
        <div class="stat-label">Documentación verificada</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">12</div>
        <div class="stat-label">Meses de garantía</div>
      </div>
    </div>
  </div>
</section>

<!-- ── DESTACADOS ────────────────────────────────────────────── -->
<% if (featuredCars.length > 0) { %>
<section class="section featured-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Destacados</div>
      <h2>Selección de la semana</h2>
      <p>Coches y campers escogidos por relación calidad-precio</p>
    </div>
    <div class="cars-grid">
      <% featuredCars.forEach(car => { %>
        <%- include('partials/car-card', { car }) %>
      <% }) %>
    </div>
    <div class="section-cta">
      <a href="/coches" class="btn btn-outline">Ver catálogo completo →</a>
    </div>
  </div>
</section>
<% } %>

<!-- ── ÚLTIMOS COCHES ────────────────────────────────────────── -->
<% if (recentCoches.length > 0) { %>
<section class="section recent-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Recién llegados</div>
      <h2>Últimos coches</h2>
    </div>
    <div class="cars-grid cars-grid-3">
      <% recentCoches.forEach(car => { %>
        <%- include('partials/car-card', { car }) %>
      <% }) %>
    </div>
    <div class="section-cta">
      <a href="/coches" class="btn btn-ghost">Ver todos los coches →</a>
    </div>
  </div>
</section>
<% } %>

<!-- ── ÚLTIMOS CAMPERS ───────────────────────────────────────── -->
<% if (recentCampers.length > 0) { %>
<section class="section recent-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Para la aventura</div>
      <h2>Últimos campers y autocaravanas</h2>
    </div>
    <div class="cars-grid cars-grid-3">
      <% recentCampers.forEach(car => { %>
        <%- include('partials/car-card', { car }) %>
      <% }) %>
    </div>
    <div class="section-cta">
      <a href="/campers" class="btn btn-ghost">Ver todos los campers →</a>
    </div>
  </div>
</section>
<% } %>

<!-- ── POR QUÉ ELEGIRNOS ─────────────────────────────────────── -->
<section class="section why-section">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">Por qué elegirnos</div>
      <h2>Compra sin sorpresas</h2>
      <p>La transparencia es el principio que guía cada operación</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Selección cuidada</h3>
        <p>Cada vehículo pasa por una inspección detallada antes de entrar en el catálogo.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3>Documentación completa</h3>
        <p>Historial, ITV, libro de mantenimiento y todos los documentos en regla desde el primer día.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Garantía incluida</h3>
        <p>12 meses de garantía mecánica para que viajes con la tranquilidad que mereces.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3>Trato cercano</h3>
        <p>Atención personalizada antes, durante y después de la compra. Estamos para ayudarte.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── CÓMO FUNCIONA ─────────────────────────────────────────── -->
<section class="section how-section" id="como-funciona">
  <div class="container">
    <div class="section-header">
      <div class="section-tag">El proceso</div>
      <h2>Así de sencillo</h2>
      <p>Desde la primera consulta hasta las llaves en tu mano</p>
    </div>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-num">01</div>
        <h3>Encuentra tu vehículo</h3>
        <p>Navega por el catálogo con todas las especificaciones, fotos y documentación de cada modelo.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-card">
        <div class="step-num">02</div>
        <h3>Contáctanos</h3>
        <p>Llámanos, escríbenos por WhatsApp o ven a verlo. Resolvemos cualquier duda sin compromiso.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-card">
        <div class="step-num">03</div>
        <h3>Pruébalo</h3>
        <p>Concertamos una prueba de conducción para que veas que el vehículo es exactamente como esperas.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-card">
        <div class="step-num">04</div>
        <h3>Llévatelo</h3>
        <p>Nos encargamos del cambio de nombre, ITV y cualquier trámite. Tú solo coge las llaves.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA FINAL ─────────────────────────────────────────────── -->
<section class="cta-section">
  <div class="container">
    <div class="cta-box">
      <div class="cta-content">
        <h2>¿Te ayudamos a encontrar tu próximo vehículo?</h2>
        <p>Más de <%= stats.disponible %> vehículo<%= stats.disponible !== 1 ? 's' : '' %> disponible<%= stats.disponible !== 1 ? 's' : '' %> ahora mismo. Contáctanos y te asesoramos sin compromiso.</p>
        <div class="cta-actions">
          <a href="/coches" class="btn btn-primary btn-lg">Ver catálogo</a>
          <a href="/contacto" class="btn btn-outline btn-lg">Contactar</a>
        </div>
      </div>
      <div class="cta-decoration">
        <div class="cta-ring cta-ring-1"></div>
        <div class="cta-ring cta-ring-2"></div>
        <div class="cta-ring cta-ring-3"></div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
