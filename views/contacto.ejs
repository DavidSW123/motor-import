<%- include('partials/header', { title: 'Contacto' }) %>

<main class="contact-page">
  <div class="container">
    <div class="contact-hero">
      <div class="section-tag">Hablemos</div>
      <h1>Te ayudamos a encontrar el vehículo perfecto</h1>
      <p>Llámanos, escríbenos o visítanos. Resolvemos cualquier duda sin compromiso.</p>
    </div>

    <div class="contact-grid">
      <a href="tel:+34618105936" class="contact-card">
        <div class="contact-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h3>Teléfono</h3>
        <p>+34 618 10 59 36</p>
        <span class="contact-card-cta">Llamar →</span>
      </a>

      <a href="mailto:carscampersbcn@gmail.com" class="contact-card">
        <div class="contact-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h3>Email</h3>
        <p>carscampersbcn@gmail.com</p>
        <span class="contact-card-cta">Escribir →</span>
      </a>

      <a href="https://wa.me/34618105936" target="_blank" rel="noopener" class="contact-card">
        <div class="contact-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
        </div>
        <h3>WhatsApp</h3>
        <p>Respuesta rápida</p>
        <span class="contact-card-cta">Abrir chat →</span>
      </a>
    </div>

    <div class="contact-info-block">
      <div class="contact-info-card">
        <h3>Horario de atención</h3>
        <ul class="contact-hours">
          <li><span>Lunes a Viernes</span><strong>9:00 – 19:00</strong></li>
          <li><span>Sábados</span><strong>10:00 – 14:00</strong></li>
          <li><span>Domingos</span><strong>Cerrado</strong></li>
        </ul>
      </div>

      <div class="contact-info-card">
        <h3>Visítanos</h3>
        <p class="contact-address">
          Dirección por confirmar<br>
          Barcelona
        </p>
        <p class="contact-note">Atendemos solo con cita previa para que podamos dedicarte el tiempo que mereces.</p>
      </div>
    </div>

    <!-- ── Formulario de contacto ────────────────────────── -->
    <section class="form-section">
      <div class="form-card">
        <div class="section-tag">Escríbenos</div>
        <h2 class="form-section-title">Cuéntanos qué necesitas</h2>
        <p class="form-section-sub">Te responderemos en menos de 24 horas laborables. También puedes contactar por teléfono o WhatsApp.</p>

        <form action="/contacto" method="post" class="big-form" novalidate>
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px" aria-hidden="true">

          <div class="form-grid-2">
            <div class="form-group">
              <label class="form-label">Nombre y apellidos <span class="req">*</span></label>
              <input type="text" name="nombre" class="form-input <%= errors && errors.includes('nombre') ? 'is-error' : '' %>"
                     value="<%= form.nombre || '' %>" required autocomplete="name">
            </div>
            <div class="form-group">
              <label class="form-label">Email <span class="req">*</span></label>
              <input type="email" name="email" class="form-input <%= errors && errors.includes('email') ? 'is-error' : '' %>"
                     value="<%= form.email || '' %>" required autocomplete="email">
            </div>
            <div class="form-group form-group-full">
              <label class="form-label">Teléfono <span class="form-label-hint">(opcional)</span></label>
              <input type="tel" name="telefono" class="form-input"
                     value="<%= form.telefono || '' %>" placeholder="+34 600 000 000" autocomplete="tel">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Mensaje <span class="req">*</span></label>
            <textarea name="mensaje" class="form-textarea <%= errors && errors.includes('mensaje') ? 'is-error' : '' %>" rows="5"
                      placeholder="Cuéntanos en qué podemos ayudarte…" required><%= form.mensaje || '' %></textarea>
          </div>

          <div class="form-actions form-actions-row">
            <button type="submit" class="btn btn-primary btn-lg">
              Enviar mensaje
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
            <a href="https://wa.me/34618105936" target="_blank" rel="noopener" class="btn btn-outline btn-lg">
              ¿Prefieres WhatsApp?
            </a>
          </div>
        </form>
      </div>
    </section>

  </div>
</main>

<%- include('partials/footer') %>
