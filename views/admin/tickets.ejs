<%- include('../partials/header', { title: 'Tickets de soporte' }) %>

<div class="admin-wrapper">
  <%- include('./sidebar', { active: 'tickets' }) %>
  <main class="admin-main">
    <div class="admin-top-bar">
      <h1 class="admin-page-title">Tickets de soporte (<%= tickets.length %>)</h1>
    </div>

    <% if (tickets.length === 0) { %>
      <div class="admin-card" style="padding:3rem;text-align:center">
        <p class="admin-empty">No hay tickets de soporte.</p>
      </div>
    <% } else { %>
      <div class="tickets-admin-list">
        <% tickets.forEach(ticket => { %>
          <div class="admin-ticket-card ticket-estado-<%= ticket.estado.replace('_','-') %>">
            <div class="admin-ticket-head">
              <div class="admin-ticket-meta">
                <h3 class="admin-ticket-subject"><%= ticket.asunto %></h3>
                <div class="admin-ticket-info">
                  <span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <%= ticket.user_nombre %> (<%= ticket.user_email %>)
                  </span>
                  <span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <%= new Date(ticket.created_at).toLocaleDateString('es-ES',{day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                  </span>
                </div>
              </div>
              <span class="badge badge-<%= ticket.estado.replace('_','-') %>"><%= ticket.estado.replace('_',' ') %></span>
            </div>

            <div class="admin-ticket-body">
              <p class="admin-ticket-msg"><%= ticket.mensaje %></p>
              <% if (ticket.respuesta) { %>
                <div class="admin-ticket-existing-response">
                  <div class="response-label">Respuesta enviada:</div>
                  <p><%= ticket.respuesta %></p>
                </div>
              <% } %>
            </div>

            <% if (ticket.estado !== 'cerrado') { %>
            <div class="admin-ticket-reply">
              <form action="/admin/tickets/<%= ticket.id %>/responder" method="post">
                <div class="reply-form-row">
                  <textarea name="respuesta" class="form-textarea form-textarea-sm" rows="3"
                            placeholder="Escribe tu respuesta…" required><%= ticket.respuesta || '' %></textarea>
                  <div class="reply-form-actions">
                    <select name="estado" class="form-select form-select-sm">
                      <option value="en_proceso" <%= ticket.estado==='en_proceso' ? 'selected' : '' %>>En proceso</option>
                      <option value="cerrado">Marcar como cerrado</option>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Enviar respuesta</button>
                  </div>
                </div>
              </form>
            </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>

<%- include('../partials/footer') %>
