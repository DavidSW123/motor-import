<%- include('partials/header', { title: 'Acceso administradores' }) %>

<main class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <a href="/" class="logo">
        <svg width="38" height="38" viewBox="0 0 32 32" fill="none">
          <rect width="32" height="32" rx="8" fill="rgba(201,162,39,0.12)"/>
          <path d="M4 22 H20 V25 Q20 26 19 26 H5 Q4 26 4 25 Z" fill="#c9a227" opacity="0.85"/>
          <rect x="6" y="14" width="12" height="8" rx="1.5" fill="#c9a227" opacity="0.7"/>
          <circle cx="8" cy="26.5" r="2" fill="#c9a227"/>
          <circle cx="16" cy="26.5" r="2" fill="#c9a227"/>
          <path d="M22 24 L24 19 L27 17 H30 V24 Z" fill="#c9a227" opacity="0.55"/>
          <circle cx="25.5" cy="25.5" r="1.5" fill="#c9a227"/>
        </svg>
        Cars<strong>&Campers</strong>
      </a>
    </div>

    <h1 class="auth-title">Acceso administradores</h1>
    <p class="auth-subtitle">Sólo personal autorizado para gestionar el catálogo</p>

    <form action="/admin/login" method="post" class="auth-form">
      <div class="form-group">
        <label class="form-label" for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" class="form-input"
               placeholder="admin@carsandcampers.es" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Contraseña</label>
        <div class="input-pwd-wrap">
          <input type="password" id="password" name="password" class="form-input"
                 placeholder="••••••••" required autocomplete="current-password">
          <button type="button" class="pwd-toggle" data-target="password" aria-label="Mostrar contraseña">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Entrar</button>
    </form>

    <a href="/" class="auth-back">← Volver al inicio</a>
  </div>

  <div class="auth-bg-decoration">
    <div class="auth-deco-ring auth-deco-ring-1"></div>
    <div class="auth-deco-ring auth-deco-ring-2"></div>
  </div>
</main>

<%- include('partials/footer') %>
