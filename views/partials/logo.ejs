<%
  // Reusable brand logo
  // Props: size (default 38), withText (default true), variant ('default'|'compact'|'mark')
  const _size  = typeof size  !== 'undefined' ? size  : 38;
  const _text  = typeof withText !== 'undefined' ? withText : true;
  const _variant = typeof variant !== 'undefined' ? variant : 'default';
  const _logoUrl = (locals.settings && locals.settings.logo_url) ? locals.settings.logo_url : '/img/logo.png';
%>
<a href="/" class="brand-logo brand-logo-<%= _variant %>" aria-label="Cars & Campers">
  <span class="brand-mark" style="width:<%= _size %>px;height:<%= _size %>px">
    <img src="<%= _logoUrl %>" alt="Cars & Campers" loading="eager"
         onerror="this.onerror=null;this.src='/img/logo.svg'">
  </span>
  <% if (_text) { %>
    <span class="brand-text">Cars<strong>&amp;Campers</strong></span>
  <% } %>
</a>
