<%
  const imgSrc = car.imagen_principal || car.imagen_primera || '/img/car-placeholder.svg';
  const precio = new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(car.precio);
  const km     = car.kilometraje.toLocaleString('es-ES');
  const isCamper = car.categoria === 'camper';
%>
<article class="car-card">
  <a href="/coches/<%= car.slug %>" class="car-card-link" tabindex="-1" aria-hidden="true">
    <div class="car-card-image">
      <img src="<%= imgSrc %>" alt="<%= car.marca %> <%= car.modelo %>" loading="lazy">
      <div class="car-card-overlay"></div>
      <% if (isCamper) { %>
        <div class="car-card-type-badge">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="2" y="9" width="14" height="9" rx="1.5"/><path d="M16 12 H22 V18 H16"/><circle cx="6" cy="20" r="2"/><circle cx="18" cy="20" r="2"/></svg>
          Camper
        </div>
      <% } %>
      <% if (car.num_imagenes > 1) { %>
        <div class="car-card-img-count">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <%= car.num_imagenes %>
        </div>
      <% } %>
    </div>
  </a>

  <div class="car-card-status-row">
    <span class="badge badge-<%= car.estado %>"><%= car.estado.replace('_',' ') %></span>
    <% if (car.destacado) { %><span class="badge badge-gold">★ Destacado</span><% } %>
  </div>

  <div class="car-card-body">
    <a href="/coches/<%= car.slug %>">
      <h3 class="car-card-title"><%= car.marca %> <%= car.modelo %></h3>
    </a>
    <div class="car-card-year"><%= car.anio %> · <span class="origin-flag"><%= car.pais_origen %></span></div>

    <div class="car-card-specs">
      <span class="car-spec">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
        <%= km %> km
      </span>
      <span class="car-spec">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 22V11l9-9 9 9v11H15v-6H9v6H3z"/><path d="M9 6h6"/></svg>
        <%= car.combustible %>
      </span>
      <span class="car-spec">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
        <%= car.transmision %>
      </span>
      <% if (isCamper && car.plazas) { %>
      <span class="car-spec">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        <%= car.plazas %> plazas
      </span>
      <% } else if (car.potencia) { %>
      <span class="car-spec">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <%= car.potencia %> CV
      </span>
      <% } %>
    </div>
  </div>

  <div class="car-card-footer">
    <span class="car-card-price"><%= precio %></span>
    <a href="/coches/<%= car.slug %>" class="btn btn-primary btn-sm">Ver detalles</a>
  </div>
</article>
