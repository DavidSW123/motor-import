<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | Cars & Campers' : 'Cars & Campers — Coches y autocaravanas seleccionados' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Selección de coches y autocaravanas con total transparencia. Documentación completa, garantía y trato cercano.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<% if (flash) { %>
  <div class="site-flash alert alert-<%= flash.type %>" id="siteFlash">
    <% if (flash.type === 'success') { %><span>✓</span><% } %>
    <% if (flash.type === 'error')   { %><span>✕</span><% } %>
    <% if (flash.type === 'warning') { %><span>⚠</span><% } %>
    <%= flash.msg %>
    <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
  </div>
<% } %>

<header class="site-header" id="site-header">
  <nav class="nav-container">
    <!-- Logo: círculo opcional + wordmark con cajas (siempre visible) -->
    <%- include('logo', {
          variant: 'header',
          showMark: !settings || settings.show_logo !== '0',
          showWordmark: true,
          markSize: 52
        }) %>

    <!-- Nav desktop -->
    <ul class="nav-links" id="navLinks">
      <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Inicio</a></li>
      <li class="has-dropdown">
        <a href="/coches" class="<%= currentPath.startsWith('/coches') ? 'active' : '' %>">
          Coches
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <ul class="nav-dropdown">
          <li><a href="/coches/nacional">Nacionales</a></li>
          <li><a href="/coches/importacion">Importación</a></li>
        </ul>
      </li>
      <li><a href="/campers" class="<%= currentPath.startsWith('/campers') ? 'active' : '' %>">Campers</a></li>
      <li class="has-dropdown">
        <a href="/servicios" class="<%= currentPath.startsWith('/servicios') ? 'active' : '' %>">
          Servicios
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <ul class="nav-dropdown">
          <li><a href="/servicios/vehiculos-a-la-carta">Vehículos a la carta</a></li>
          <li><a href="/servicios/techos-elevables">Techos elevables</a></li>
        </ul>
      </li>
      <li><a href="/#como-funciona">Cómo funciona</a></li>
      <li><a href="/contacto" class="<%= currentPath === '/contacto' ? 'active' : '' %>">Contacto</a></li>
    </ul>

    <!-- Acciones -->
    <div class="nav-actions">
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="btn btn-outline btn-sm">⚙ Panel admin</a>
        <a href="/admin/logout" class="btn btn-ghost btn-sm">Salir</a>
      <% } else { %>
        <a href="/contacto" class="btn btn-primary btn-sm">Contactar</a>
      <% } %>

      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Menú móvil -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/" class="mobile-nav-item">Inicio</a>
    <a href="/coches" class="mobile-nav-item">Coches</a>
    <a href="/coches/nacional" class="mobile-nav-item mobile-nav-sub">— Nacionales</a>
    <a href="/coches/importacion" class="mobile-nav-item mobile-nav-sub">— Importación</a>
    <a href="/campers" class="mobile-nav-item">Campers</a>
    <a href="/servicios" class="mobile-nav-item">Servicios</a>
    <a href="/servicios/vehiculos-a-la-carta" class="mobile-nav-item mobile-nav-sub">— Vehículos a la carta</a>
    <a href="/servicios/techos-elevables" class="mobile-nav-item mobile-nav-sub">— Techos elevables</a>
    <a href="/#como-funciona" class="mobile-nav-item">Cómo funciona</a>
    <a href="/contacto" class="mobile-nav-item mobile-cta">Contacto</a>
    <% if (user && user.role === 'admin') { %>
      <a href="/admin" class="mobile-nav-item">⚙ Panel admin</a>
      <a href="/admin/logout" class="mobile-nav-item mobile-logout">Cerrar sesión</a>
    <% } %>
  </div>
</header>
