<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
    const SITE_URL = 'https://carscampers.com';
    const pageTitle = (typeof title !== 'undefined')
      ? title + ' | Cars & Campers'
      : 'Cars & Campers — Coches y autocaravanas seleccionados en Barcelona';
    const pageDesc  = (typeof description !== 'undefined')
      ? description
      : 'Concesionario premium en Barcelona. Coches nacionales y de importación + autocaravanas con documentación completa, garantía y trato cercano.';
    const _currentPath = (typeof currentPath !== 'undefined') ? currentPath : '/';
    const canonical = SITE_URL + _currentPath;
    // OJO: no usar 'const ogImage' aquí porque entra en TDZ con la
    //   variable passada como local desde include(). Usamos otro nombre.
    const ogImageUrl = (typeof ogImage !== 'undefined') ? ogImage : (SITE_URL + '/img/logo.png');
  %>
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDesc %>">

  <!-- SEO básico -->
  <link rel="canonical" href="<%= canonical %>">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#b91c1c">
  <meta name="author" content="Cars & Campers BCN">

  <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Cars & Campers BCN">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:image" content="<%= ogImageUrl %>">
  <meta property="og:locale" content="es_ES">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <meta name="twitter:image" content="<%= ogImageUrl %>">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/img/logo.png">

  <!-- Fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Estilos -->
  <link rel="stylesheet" href="/css/style.css?v=20260514c">

  <!-- Schema.org: organización (mejora cómo Google entiende el sitio) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AutoDealer",
    "name": "Cars & Campers BCN",
    "url": "https://carscampers.com",
    "logo": "https://carscampers.com/img/logo.png",
    "telephone": "+34 645 10 46 55",
    "email": "carscampersbcn@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Barcelona",
      "addressCountry": "ES"
    },
    "areaServed": "ES",
    "description": "Concesionario premium en Barcelona. Coches nacionales y de importación + autocaravanas con documentación completa, garantía y trato cercano."
  }
  </script>
</head>
<body class="<%= (currentPath === '/' || currentPath === '') ? 'is-home home-hero-active' : '' %>">

<% if (flash) { %>
  <div class="site-flash alert alert-<%= flash.type %>" id="siteFlash">
    <% if (flash.type === 'success') { %><span>✓</span><% } %>
    <% if (flash.type === 'error')   { %><span>✕</span><% } %>
    <% if (flash.type === 'warning') { %><span>⚠</span><% } %>
    <%= flash.msg %>
    <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
  </div>
<% } %>

<header class="site-header" id="site-header">
  <nav class="nav-container">
    <!-- Logo: círculo opcional + wordmark con cajas (siempre visible) -->
    <%- include('logo', {
          variant: 'header',
          showMark: !settings || settings.show_logo !== '0',
          showWordmark: true,
          markSize: 52
        }) %>

    <!-- Nav desktop -->
    <ul class="nav-links" id="navLinks">
      <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Inicio</a></li>
      <li class="has-dropdown">
        <a href="/coches" class="<%= currentPath.startsWith('/coches') ? 'active' : '' %>">
          Vehículos
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <ul class="nav-dropdown">
          <li><a href="/coches/nacional">Nacionales</a></li>
          <li><a href="/coches/importacion">Importación</a></li>
        </ul>
      </li>
      <li><a href="/campers" class="<%= currentPath.startsWith('/campers') ? 'active' : '' %>">Campers</a></li>
      <li class="has-dropdown">
        <a href="/servicios" class="<%= currentPath.startsWith('/servicios') ? 'active' : '' %>">
          Servicios
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <ul class="nav-dropdown">
          <li><a href="/servicios/vehiculos-a-la-carta">Vehículos a la carta</a></li>
          <li><a href="/servicios/techos-elevables">Techos elevables</a></li>
        </ul>
      </li>
      <li><a href="/#como-funciona">Cómo funciona</a></li>
      <li><a href="/contacto" class="<%= currentPath === '/contacto' ? 'active' : '' %>">Contacto</a></li>
    </ul>

    <!-- Acciones -->
    <div class="nav-actions">
      <% if (user && user.role === 'admin') { %>
        <a href="/admin" class="btn btn-outline btn-sm">⚙ Panel admin</a>
        <a href="/admin/logout" class="btn btn-ghost btn-sm">Salir</a>
      <% } else { %>
        <a href="/contacto" class="btn btn-primary btn-sm">Contactar</a>
      <% } %>

      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Menú móvil -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/" class="mobile-nav-item">Inicio</a>
    <a href="/coches" class="mobile-nav-item">Vehículos</a>
    <a href="/coches/nacional" class="mobile-nav-item mobile-nav-sub">— Nacionales</a>
    <a href="/coches/importacion" class="mobile-nav-item mobile-nav-sub">— Importación</a>
    <a href="/campers" class="mobile-nav-item">Campers</a>
    <a href="/servicios" class="mobile-nav-item">Servicios</a>
    <a href="/servicios/vehiculos-a-la-carta" class="mobile-nav-item mobile-nav-sub">— Vehículos a la carta</a>
    <a href="/servicios/techos-elevables" class="mobile-nav-item mobile-nav-sub">— Techos elevables</a>
    <a href="/#como-funciona" class="mobile-nav-item">Cómo funciona</a>
    <a href="/contacto" class="mobile-nav-item mobile-cta">Contacto</a>
    <% if (user && user.role === 'admin') { %>
      <a href="/admin" class="mobile-nav-item">⚙ Panel admin</a>
      <a href="/admin/logout" class="mobile-nav-item mobile-logout">Cerrar sesión</a>
    <% } %>
  </div>
</header>
