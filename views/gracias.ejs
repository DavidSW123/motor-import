<%- include('partials/header', { title: '¡Gracias!' }) %>

<main class="thanks-page">
  <div class="container">
    <div class="thanks-card">
      <div class="thanks-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      </div>

      <% if (tipo === 'a-la-carta') { %>
        <div class="section-tag">Solicitud recibida</div>
        <h1>¡Gracias, <%= nombre.split(' ')[0] %>!</h1>
        <p class="thanks-sub">
          Hemos recibido tu solicitud a la carta. <strong>En breve nos pondremos en contacto contigo</strong>
          para concretar los detalles y enviarte el contrato de aceptación de costes antes de iniciar la búsqueda.
        </p>
      <% } else if (tipo === 'techo-elevable') { %>
        <div class="section-tag">Presupuesto solicitado</div>
        <h1>¡Gracias, <%= nombre.split(' ')[0] %>!</h1>
        <p class="thanks-sub">
          Hemos recibido los datos de tu vehículo. <strong>Te enviaremos un presupuesto detallado en menos de 48 horas laborables</strong>
          con el modelo de techo recomendado, materiales y plazo de instalación.
        </p>
      <% } else { %>
        <div class="section-tag">Mensaje enviado</div>
        <h1>¡Gracias, <%= nombre.split(' ')[0] %>!</h1>
        <p class="thanks-sub">
          Hemos recibido tu mensaje. <strong>Te responderemos en menos de 24 horas laborables.</strong>
        </p>
      <% } %>

      <div class="thanks-info">
        <div class="thanks-info-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <strong>Te hemos enviado una copia a tu email</strong>
          <p>Hemos enviado los datos a <strong><%= email %></strong>. Si no llega en unos minutos, revisa la carpeta de spam.</p>
        </div>
      </div>

      <div class="thanks-actions">
        <a href="/" class="btn btn-primary btn-lg">Volver al inicio</a>
        <a href="https://wa.me/34645104655" target="_blank" rel="noopener" class="btn btn-outline btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
          WhatsApp directo
        </a>
      </div>

      <p class="thanks-foot">
        ¿Tienes alguna duda urgente? Llámanos al
        <a href="tel:+34645104655">+34 645 10 46 55</a>.
      </p>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
